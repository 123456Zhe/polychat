{
  "name": "polychat",
  "version": "1.0.0",
  "private": true,
  "description": "A persistent chat server with Web, GUI and TUI clients",
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "test": "node --test test/*.test.mjs",
    "web:dev": "vite --config web-client/vite.config.js",
    "web:build": "vite build --config web-client/vite.config.js"
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "katex": "0.16.11",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^6.0.5"
  }
}
